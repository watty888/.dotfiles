# Kanshi configuration for display profiles

# Profile 1: External monitor only (activates when both HDMI-A-2 and eDP-1 are connected)
profile docked {
  output 'Dell Inc. DELL S3425DW DVLPR44' enable mode 3440x1440@59.973
  output eDP-1 disable
}

# Profile 2: Laptop only (activates when only eDP-1 is connected)
profile {
  output eDP-1 enable
}
